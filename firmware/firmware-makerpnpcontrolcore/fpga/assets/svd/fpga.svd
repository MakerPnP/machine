<?xml version="1.0" encoding="UTF-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance">
  <name>fpga</name>
  <version>1.0</version>
  <description>memory-mapped fpga registers over qspi/ospi</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>

  <peripherals>

    <!-- system1 block (0x0000 - 0x003f) -->
    <peripheral>
      <name>system1</name>
      <description>system block 1</description>
      <baseAddress>0x90000000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>

      <registers>

        <register>
          <name>ident</name>
          <description>device identifier</description>
          <addressOffset>0x0000</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0xFACEB00B</resetValue>
          <fields>
            <field>
              <name>ident</name>
              <description>device identifier</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>version</name>
          <description>version information</description>
          <addressOffset>0x0004</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x01020304</resetValue>
          <fields>

            <field>
              <name>major</name>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
            </field>

            <field>
              <name>minor</name>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
            </field>

            <field>
              <name>patch</name>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>

            <field>
              <name>build</name>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>

          </fields>
        </register>

      </registers>
    </peripheral>


    <!-- led block (0x0040 - 0x007f) -->
    <peripheral>
      <name>led</name>
      <description>led control block</description>
      <baseAddress>0x90000040</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>

      <registers>

        <register>
          <name>led_ctrl</name>
          <description>led control register</description>
          <addressOffset>0x0000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>

            <field>
              <name>fpga_led</name>
              <description>fpga activity led (0 = off)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>mcu_led</name>
              <description>mcu activity led (0 = off)</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
            </field>

          </fields>
        </register>

      </registers>
    </peripheral>

    <!-- io block (0x0080 - 0x00bf) -->
    <peripheral>
      <name>io</name>
      <description>io control block</description>
      <baseAddress>0x90000080</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>

      <registers>

        <register>
          <name>io_ctrl</name>
          <description>io control register</description>
          <addressOffset>0x0000</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>

            <field>
              <name>reserved</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>

          </fields>
        </register>

        <register>
          <name>io_in_1</name>
          <description>io in 1 register</description>
          <addressOffset>0x0004</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>user0</name>
              <description>user 0 button (1 = pressed)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>user1</name>
              <description>user 1 button (1 = pressed)</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>iak1</name>
              <description>optical input 1 (optical isolator anode cathode)</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>iak2</name>
              <description>optical input 2 (optical isolator anode cathode)</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>reserved1</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>

            <field>
              <name>base_present</name>
              <description>base present detect</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>reserved2</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>9</bitOffset>
              <bitWidth>3</bitWidth>
            </field>

            <field>
              <name>port_present</name>
              <description>port present detect</description>
              <bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
            </field>

            <field>
              <name>reserved3</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>io_in_2</name>
          <description>io in 2 register</description>
          <addressOffset>0x0008</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>din</name>
              <description>digital in 8 to 1 (ordering = 7:0)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>io_out_1</name>
          <description>io out 1 register</description>
          <addressOffset>0x0010</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>

            <field>
              <name>oec1</name>
              <description>optical output 1 (optical isolator emitter collector)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>oec2</name>
              <description>optical output 2 (optical isolator emitter collector)</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>reserved1</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>2</bitOffset>
              <bitWidth>6</bitWidth>
            </field>

            <field>
              <name>adc_mux_sel</name>
              <description>ADC Mux input select</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
            </field>

            <field>
              <name>reserved2</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
            </field>

          </fields>
        </register>

      </registers>
    </peripheral>


    <!-- buzzer block (0x00c0 - 0x00ff) -->
    <peripheral>
      <name>buzzer</name>
      <description>buzzer control block</description>
      <baseAddress>0x900000c0</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>

      <registers>

        <register>
          <name>buzzer_ctrl</name>
          <description>buzzer control register</description>
          <addressOffset>0x0000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>buzzer</name>
              <description>buzzer control (0 = off)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>1</bitOffset>
              <bitWidth>31</bitWidth>
            </field>
          </fields>
        </register>

      </registers>
    </peripheral>


    <!-- encoders block (0x0100 - 0x013f) -->
    <peripheral>
      <name>encoders</name>
      <description>encoders control block</description>
      <baseAddress>0x90000100</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>

      <registers>

        <register>
          <name>enc_ctrl</name>
          <description>encoders control register</description>
          <addressOffset>0x0000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>

            <field>
              <name>reset</name>
              <description>reset encoders (1 = reset)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>31</bitWidth>
            </field>

          </fields>
        </register>

        <register>
          <name>enc_set_count_a</name>
          <description>set encoder a counter</description>
          <addressOffset>0x0004</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_set_count_b</name>
          <description>set encoder b counter</description>
          <addressOffset>0x0008</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_set_count_c</name>
          <description>set encoder c counter</description>
          <addressOffset>0x000c</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_set_count_x</name>
          <description>set encoder x counter</description>
          <addressOffset>0x0010</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_set_count_y</name>
          <description>set encoder y counter</description>
          <addressOffset>0x0014</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_set_count_z</name>
          <description>set encoder z counter</description>
          <addressOffset>0x0018</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_count_a</name>
          <description>encoder a counter</description>
          <addressOffset>0x0020</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_count_b</name>
          <description>encoder b counter</description>
          <addressOffset>0x0024</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

        <register>
          <name>enc_count_c</name>
          <description>encoder c counter</description>
          <addressOffset>0x0028</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>enc_count_x</name>
          <description>encoder x counter</description>
          <addressOffset>0x002c</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>enc_count_y</name>
          <description>encoder y counter</description>
          <addressOffset>0x0030</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>enc_count_z</name>
          <description>encoder z counter</description>
          <addressOffset>0x0034</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>value</name>
              <description>encoder counter value</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, ignored</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
            </field>
          </fields>
        </register>

      </registers>
    </peripheral>

    <!-- system2 block (0x01c0 - 0x01ff) -->
    <peripheral>
      <name>system2</name>
      <description>system block 2</description>
      <baseAddress>0x900001c0</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>

      <registers>

        <register>
          <name>marker</name>
          <description>fixed marker value</description>
          <addressOffset>0x003c</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0xdeadc0de</resetValue>
          <fields>
            <field>
              <name>marker</name>
              <description>fixed marker</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>

      </registers>
    </peripheral>


    <!-- ws2812_1 block (0x0140 - 0x017f) -->
    <peripheral>
      <name>ws2812_1</name>
      <description>ws2812 RGB LED block</description>
      <baseAddress>0x90000140</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x40</size>
        <usage>registers</usage>
      </addressBlock>

      <registers>

        <register>
          <name>ws_ctrl</name>
          <description>led control register</description>
          <addressOffset>0x0000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>

            <field>
              <name>enabled</name>
              <description>enable led output (1 = on)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>

            <field>
              <name>mode</name>
              <description>ws2812 color mode</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>

              <enumeratedValues>

                <enumeratedValue>
                  <name>RGB</name>
                  <description>rgb ordering</description>
                  <value>0</value>
                </enumeratedValue>

                <enumeratedValue>
                  <name>RGBW</name>
                  <description>rgbw ordering</description>
                  <value>1</value>
                </enumeratedValue>

                <enumeratedValue>
                  <name>GRB</name>
                  <description>grb ordering</description>
                  <value>2</value>
                </enumeratedValue>

                <enumeratedValue>
                  <name>GRBW</name>
                  <description>grbw ordering</description>
                  <value>3</value>
                </enumeratedValue>

              </enumeratedValues>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>3</bitOffset>
              <bitWidth>29</bitWidth>
            </field>

          </fields>
        </register>

        <register>
          <name>ws_tx_config</name>
          <description>ws2812 transmit configuration</description>
          <addressOffset>0x04</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>

            <field>
              <name>leds_count</name>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
            </field>

            <field>
              <name>reserved</name>
              <description>reserved, keep at reset value</description>
              <bitOffset>8</bitOffset>
              <bitWidth>24</bitWidth>
            </field>

          </fields>
        </register>

        <!-- ws_data registers -->
        <register>
          <name>ws_data_0</name>
          <description>rgb(w) input</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>b</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>g</name><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>r</name><bitOffset>16</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>w</name><bitOffset>24</bitOffset><bitWidth>8</bitWidth></field>
          </fields>
        </register>

        <register>
          <name>ws_data_1</name>
          <description>rgb(w) input</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>b</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>g</name><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>r</name><bitOffset>16</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>w</name><bitOffset>24</bitOffset><bitWidth>8</bitWidth></field>
          </fields>
        </register>

        <register>
          <name>ws_data_2</name>
          <description>rgb(w) input</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>b</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>g</name><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>r</name><bitOffset>16</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>w</name><bitOffset>24</bitOffset><bitWidth>8</bitWidth></field>
          </fields>
        </register>

        <register>
          <name>ws_data_3</name>
          <description>rgb(w) input</description>
          <addressOffset>0x1c</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field><name>b</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>g</name><bitOffset>8</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>r</name><bitOffset>16</bitOffset><bitWidth>8</bitWidth></field>
            <field><name>w</name><bitOffset>24</bitOffset><bitWidth>8</bitWidth></field>
          </fields>
        </register>

        <register>
          <name>ws_data_4</name>
          <description>rgb(w) input</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <access>read-write</access>
